rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() {
      return signedIn() && myRole() == 'admin';
    }

    // One profile doc per account, keyed by uid.
    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      // Users may update their own non-role fields; only an admin may change role/active.
      allow update: if signedIn() && (
        (request.auth.uid == uid &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.active == resource.data.active)
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Single shared document holding the whole tracker dataset, synced in real time.
    match /pmoData/{docId} {
      allow read, write: if signedIn();
    }
  }
}
